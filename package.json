{
  "name": "comp307-booking-app",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "client": "npm run dev -w client",
    "server": "npm run dev -w server",
    "build": "npm run build -w client",
    "seed:random": "npm run seed:random -w server",
    "seed:owner-bookings": "npm run seed:owner-bookings -w server --"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "vite": "^6.4.2"
  }
}
